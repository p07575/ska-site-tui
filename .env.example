# Default UI language for new sessions: "en" or "zh-TW".
# Visitors can switch live in the TUI with Ctrl+L.
DEFAULT_LOCALE=en

# Halo blog base URL (the content source).
# ⚠ NEVER use http://localhost:8090 here — inside the container "localhost" is
#   the container itself, not your Halo. Use one of:
#     • your public blog URL: https://blog.jasonxiang.net   (simplest, works anywhere)
#     • the Halo CONTAINER name on the shared network: http://<halo-container>:8090
#       (find it with:  docker ps --format '{{.Names}}' | grep -i halo )
#     • the host IP if Halo's port is published: http://192.168.31.65:8090
HALO_BASE_URL=https://blog.jasonxiang.net

# Memory system backend (optional — leave blank to disable).
HINDSIGHT_API_URL=

# AI chat panel — OFF by default. To enable, set ENABLE_AI=true AND fill all
# three AI_* below with a real OpenAI-compatible endpoint.
ENABLE_AI=false
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# OpenTUI debug console.
# ⚠ OpenTUI treats ANY non-empty value as TRUE (so "false" == true!).
#   OTUI_USE_CONSOLE=1  captures logs off-screen (keeps them from garbling the UI).
#   SHOW_CONSOLE (blank) keeps the console pane HIDDEN — set it to anything and
#   the console splits the screen. Leave it EMPTY.
OTUI_USE_CONSOLE=1
SHOW_CONSOLE=

# SSH port the TUI listens on INSIDE the container (kept internal; not published).
PORT=2222
